{
  "name": "ReadjustmentRule",
  "type": "object",
  "properties": {
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o do reajuste"
    },
    "reference_month": {
      "type": "string",
      "description": "M\u00eas de refer\u00eancia (YYYY-MM)"
    },
    "readjustment_scope": {
      "type": "string",
      "enum": [
        "payroll_type",
        "employee"
      ],
      "default": "payroll_type",
      "description": "Escopo: por folha de pagamento / colaborador espec\u00edfico"
    },
    "payroll_type": {
      "type": "string",
      "description": "Tipo de folha (quando scope=payroll_type)"
    },
    "company_id": {
      "type": "string",
      "description": "ID da empresa"
    },
    "employee_id": {
      "type": "string",
      "description": "ID do colaborador (quando scope=employee)"
    },
    "excluded_employee_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "IDs de colaboradores exclu\u00eddos do reajuste"
    },
    "effective_salary_pct": {
      "type": "number",
      "default": 0
    },
    "meal_voucher_day_value_pct": {
      "type": "number",
      "default": 0
    },
    "food_voucher_day_value_pct": {
      "type": "number",
      "default": 0
    },
    "motorcycle_rental_pct": {
      "type": "number",
      "default": 0
    },
    "hazard_pay_pct_on_salary": {
      "type": "number",
      "default": 30
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "applying",
        "applied",
        "reverted"
      ],
      "default": "draft"
    },
    "applied_date": {
      "type": "string"
    },
    "reverted_date": {
      "type": "string"
    },
    "affected_entries_count": {
      "type": "number",
      "default": 0
    },
    "progress_total": {
      "type": "number",
      "default": 0,
      "description": "Total de folhas a processar (para barra de progresso)"
    },
    "affected_payroll_entries_snapshot": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": [],
      "description": "Snapshot das folhas originais (para revers\u00e3o do reajuste salarial)"
    },
    "union_contrib_applied": {
      "type": "boolean",
      "default": false,
      "description": "Ajuste de contribui\u00e7\u00e3o assistencial aplicado (total ou parcial)"
    },
    "union_contrib_in_progress": {
      "type": "boolean",
      "default": false,
      "description": "Indica que o ajuste de contribui\u00e7\u00e3o assistencial est\u00e1 em processamento"
    },
    "union_contrib_applied_date": {
      "type": "string"
    },
    "union_contrib_reverted_date": {
      "type": "string"
    },
    "union_contrib_updated_count": {
      "type": "number",
      "default": 0
    },
    "union_contrib_progress_total": {
      "type": "number",
      "default": 0,
      "description": "Total de folhas a processar no ajuste de contribui\u00e7\u00e3o (para barra de progresso)"
    },
    "union_contrib_snapshot": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": [],
      "description": "Snapshot incremental dos campos de contribui\u00e7\u00e3o assistencial \u2014 cresce \u00e0 medida que entradas s\u00e3o processadas (suporte a estorno parcial)"
    }
  },
  "required": [
    "reference_month",
    "readjustment_scope"
  ]
}